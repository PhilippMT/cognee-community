# === LLM Configuration (required for cognee) ===
LLM_API_KEY=your_openai_api_key
LLM_MODEL=openai/gpt-4o-mini
LLM_PROVIDER=openai
# LLM_ENDPOINT=http://localhost:11434/v1  # For Ollama: must include /v1 suffix

# === Embedding Configuration ===
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-large
# EMBEDDING_ENDPOINT=http://localhost:11434/api/embed  # For Ollama
# EMBEDDING_DIMENSIONS=2560
# HUGGINGFACE_TOKENIZER=Qwen/Qwen3-Embedding-4B

# === Structured Output Framework (optional, default: instructor) ===
# STRUCTURED_OUTPUT_FRAMEWORK=baml

# --- AWS Bedrock example ---
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# LLM_PROVIDER=bedrock
# LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# STRUCTURED_OUTPUT_FRAMEWORK=baml
# BAML_LLM_PROVIDER=aws-bedrock
# BAML_LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# EMBEDDING_PROVIDER=bedrock
# EMBEDDING_MODEL=bedrock/amazon.titan-embed-text-v2:0
# EMBEDDING_DIMENSIONS=1024

# === Web Enrichment (optional, for /enrich/web endpoints) ===
TAVILY_API_KEY=your_tavily_api_key

# === Server Configuration ===
HOST=0.0.0.0
PORT=8000

# === Cognee Settings ===
ENABLE_BACKEND_ACCESS_CONTROL=false
